{
  "appId": "com.wg.vortext",
  "productName": "WGVortex",
  "directories": {
    "output": "dist"
  },
  "files": ["out/**/*", "package.json"],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true
  }
}
